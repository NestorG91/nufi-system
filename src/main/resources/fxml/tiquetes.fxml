<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.nufi.ui.controllers.TiquetesController"
      spacing="16">

    <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>

    <!-- ══ ENCABEZADO ══ -->
    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label text="🧾 Tiquetes de Pago"
               styleClass="label-titulo"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="💰 Generar Pago"
                styleClass="btn-primary"
                onAction="#abrirGenerarPago"/>
    </HBox>

    <!-- ══ FILTROS ══ -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Filtrar por trabajador:"/>
        <ComboBox fx:id="cmbFiltroTrabajador"
                  promptText="Todos"
                  prefWidth="200"
                  styleClass="nufi-input"/>
        <Button text="🔍 Filtrar"
                styleClass="btn-secondary"
                onAction="#filtrar"/>
        <Button text="↺ Limpiar"
                styleClass="btn-secondary"
                onAction="#limpiarFiltro"/>
    </HBox>

    <!-- ══ TABLA ══ -->
    <TableView fx:id="tablaTiquetes"
               VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colNumero"
                         text="N°" prefWidth="60"/>
            <TableColumn fx:id="colTrabajador"
                         text="Trabajador" prefWidth="160"/>
            <TableColumn fx:id="colFecha"
                         text="Fecha Pago" prefWidth="120"/>
            <TableColumn fx:id="colLabor"
                         text="Labor" prefWidth="120"/>
            <TableColumn fx:id="colLote"
                         text="Lote" prefWidth="120"/>
            <TableColumn fx:id="colTotal"
                         text="Total $" prefWidth="120"/>
            <TableColumn fx:id="colEstado"
                         text="Estado" prefWidth="100"/>
            <TableColumn fx:id="colAcciones"
                         text="Acciones" prefWidth="140"/>
        </columns>
    </TableView>

    <!-- ══ PANEL GENERAR PAGO ══ -->
    <VBox fx:id="panelPago"
          styleClass="card"
          spacing="12"
          visible="false"
          managed="false">

        <Label text="Generar Tiquete de Pago"
               styleClass="card-titulo"/>

        <HBox spacing="12">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Trabajador:"/>
                <ComboBox fx:id="cmbTrabajador"
                          promptText="Seleccionar..."
                          maxWidth="Infinity"
                          styleClass="nufi-input"/>
            </VBox>
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Fecha de pago:"/>
                <DatePicker fx:id="dpFechaPago"
                            maxWidth="Infinity"
                            styleClass="nufi-input"/>
            </VBox>
        </HBox>

        <HBox spacing="12">
            <VBox spacing="4" HBox.hgrow="ALWAYS">
                <Label text="Medio de pago:"/>
                <ComboBox fx:id="cmbMedioPago"
                          promptText="Efectivo, Transferencia, Nequi..."
                          maxWidth="Infinity"
                          styleClass="nufi-input"/>
            </VBox>
        </HBox>

        <!-- Jornadas pendientes de pago -->
        <Label text="Jornadas pendientes de pago:"
               style="-fx-font-weight:bold;"/>
        <VBox fx:id="panelJornadas" spacing="4"/>

        <!-- Total -->
        <HBox spacing="8" alignment="CENTER_LEFT">
            <Label text="TOTAL A PAGAR:"
                   style="-fx-font-weight:bold; -fx-font-size:14px;"/>
            <Label fx:id="lblTotalPagar"
                   text="0"
                   style="-fx-font-weight:bold; -fx-font-size:18px; -fx-text-fill:#2d6a4f;"/>
        </HBox>

        <VBox spacing="4">
            <Label text="Observaciones (medio de pago, notas):"/>
            <TextArea fx:id="txtObservaciones"
                      promptText="Ej: Pago por Nequi al 300 123 4567"
                      prefRowCount="2"
                      wrapText="true"
                      styleClass="nufi-input"/>
        </VBox>

        <Label fx:id="lblError"
               styleClass="label-error"
               visible="false"
               managed="false"/>

        <HBox spacing="8">
            <Button text="🖨️ Generar Tiquete"
                    styleClass="btn-primary"
                    onAction="#generarTiquete"/>
            <Button text="Cancelar"
                    styleClass="btn-secondary"
                    onAction="#cancelar"/>
        </HBox>
    </VBox>
</VBox>